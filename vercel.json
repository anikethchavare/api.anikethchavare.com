{
    "builds": [
        {
            "src": "server.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "server.py"
        }
    ],
    "crons": [
        {
            "path": "/clear-request-logs",
            "schedule": "0 0 1 * *"
        }
    ]
}